//Hardware Pin Definitions

// Example symbolic definitions only
#define PHONE_SENSOR_PIN     0
#define BTN_ADD_HOUR_PIN     1
#define BTN_ADD_30MIN_PIN    2
#define STATUS_LED_PIN       3

//Constants

#define SECONDS_PER_HOUR     3600U
#define SECONDS_PER_30MIN    1800U
#define MAX_SESSION_TIME     14400U   // 4 hours max
#define DISPLAY_BUFFER_SIZE  64

//State Machine

typedef enum
{
    STATE_IDLE = 0,
    STATE_TIMER_SETUP,
    STATE_ACTIVE,
    STATE_COMPLETE,
    STATE_INTERRUPTED
} SystemState;

//Global Variables

volatile SystemState currentState = STATE_IDLE;

volatile uint32_t selectedTimeSeconds = 0;
volatile uint32_t remainingTimeSeconds = 0;

volatile bool phonePresent = false;
volatile bool sessionRunning = false;
volatile bool displayUpdateRequired = true;
volatile bool oneSecondTick = false;

//Function Prototypes

void System_Init(void);
void GPIO_Init(void);
void Timer_Init(void);
void OLED_Init(void);

void OLED_Clear(void);
void OLED_PrintLine(uint8_t line, const char *text);
void OLED_ShowIdleScreen(void);
void OLED_ShowSetupScreen(uint32_t timeSeconds);
void OLED_ShowActiveScreen(uint32_t remainingSeconds);
void OLED_ShowCompleteScreen(void);
void OLED_ShowInterruptedScreen(void);

void EnterState(SystemState newState);
void Handle_IdleState(void);
void Handle_SetupState(void);
void Handle_ActiveState(void);
void Handle_CompleteState(void);
void Handle_InterruptedState(void);

void StartSession(void);
void StopSession(void);
void ResetSession(void);

void UpdateDisplay(void);
void FormatTime(uint32_t totalSeconds, char *buffer, size_t len);

//Main

int main(void)
{
    System_Init();
    EnterState(STATE_IDLE);

    while (1)
    {
        if (oneSecondTick)
        {
            oneSecondTick = false;

            if (currentState == STATE_ACTIVE && sessionRunning)
            {
                if (remainingTimeSeconds > 0)
                {
                    remainingTimeSeconds--;
                    displayUpdateRequired = true;
                }

                if (remainingTimeSeconds == 0)
                {
                    sessionRunning = false;
                    EnterState(STATE_COMPLETE);
                }
            }
        }

        switch (currentState)
        {
            case STATE_IDLE:
                Handle_IdleState();
                break;

            case STATE_TIMER_SETUP:
                Handle_SetupState();
                break;

            case STATE_ACTIVE:
                Handle_ActiveState();
                break;

            case STATE_COMPLETE:
                Handle_CompleteState();
                break;

            case STATE_INTERRUPTED:
                Handle_InterruptedState();
                break;

            default:
                EnterState(STATE_IDLE);
                break;
        }

        if (displayUpdateRequired)
        {
            UpdateDisplay();
            displayUpdateRequired = false;
        }
    }
}

