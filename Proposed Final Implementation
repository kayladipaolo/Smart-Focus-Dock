//State Entry

void EnterState(SystemState newState)
{
    currentState = newState;
    displayUpdateRequired = true;

    switch (newState)
    {
        case STATE_IDLE:
            ResetSession();
            break;

        case STATE_TIMER_SETUP:
            break;

        case STATE_ACTIVE:
            StartSession();
            break;

        case STATE_COMPLETE:
            StopSession();
            break;

        case STATE_INTERRUPTED:
            StopSession();
            break;

        default:
            break;
    }
}

//State Handlers

void Handle_IdleState(void)
{
    /* Wait for user to begin selecting a session duration */
    if (selectedTimeSeconds == 0)
    {
        return;
    }

    EnterState(STATE_TIMER_SETUP);
}

void Handle_SetupState(void)
{
    /* Once a valid time is set, session begins when phone is placed */
    if (selectedTimeSeconds > 0 && phonePresent)
    {
        EnterState(STATE_ACTIVE);
    }
}

void Handle_ActiveState(void)
{
    /* If phone is removed early, interrupt session */
    if (!phonePresent && sessionRunning)
    {
        EnterState(STATE_INTERRUPTED);
    }
}

void Handle_CompleteState(void)
{
    /* In real implementation, could wait for user acknowledgement
       or automatically return to idle after a timeout */
}

void Handle_InterruptedState(void)
{
    /* In real implementation, could flash LED/buzzer briefly
       before returning to idle */
}

//Session Control

void StartSession(void)
{
    remainingTimeSeconds = selectedTimeSeconds;
    sessionRunning = true;
}

void StopSession(void)
{
    sessionRunning = false;
}

void ResetSession(void)
{
    selectedTimeSeconds = 0;
    remainingTimeSeconds = 0;
    sessionRunning = false;
    phonePresent = false;
}

//Display Logic

void UpdateDisplay(void)
{
    switch (currentState)
    {
        case STATE_IDLE:
            OLED_ShowIdleScreen();
            break;

        case STATE_TIMER_SETUP:
            OLED_ShowSetupScreen(selectedTimeSeconds);
            break;

        case STATE_ACTIVE:
            OLED_ShowActiveScreen(remainingTimeSeconds);
            break;

        case STATE_COMPLETE:
            OLED_ShowCompleteScreen();
            break;

        case STATE_INTERRUPTED:
            OLED_ShowInterruptedScreen();
            break;

        default:
            OLED_ShowIdleScreen();
            break;
    }
}

void OLED_ShowIdleScreen(void)
{
    OLED_Clear();
    OLED_PrintLine(0, "Smart Focus Dock");
    OLED_PrintLine(1, "Select time");
}

void OLED_ShowSetupScreen(uint32_t timeSeconds)
{
    char timeBuffer[DISPLAY_BUFFER_SIZE];

    OLED_Clear();
    OLED_PrintLine(0, "Set Session Time");
    FormatTime(timeSeconds, timeBuffer, sizeof(timeBuffer));
    OLED_PrintLine(1, timeBuffer);
}

void OLED_ShowActiveScreen(uint32_t remainingSeconds)
{
    char timeBuffer[DISPLAY_BUFFER_SIZE];

    OLED_Clear();
    OLED_PrintLine(0, "Focus Active");
    FormatTime(remainingSeconds, timeBuffer, sizeof(timeBuffer));
    OLED_PrintLine(1, timeBuffer);
}

void OLED_ShowCompleteScreen(void)
{
    OLED_Clear();
    OLED_PrintLine(0, "Session Complete");
    OLED_PrintLine(1, "Good work");
}

void OLED_ShowInterruptedScreen(void)
{
    OLED_Clear();
    OLED_PrintLine(0, "Session Interrupted");
    OLED_PrintLine(1, "Phone removed");
}

