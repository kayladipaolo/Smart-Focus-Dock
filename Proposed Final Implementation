void FormatTime(uint32_t totalSeconds, char *buffer, size_t len)
{
    uint32_t hours = totalSeconds / 3600U;
    uint32_t minutes = (totalSeconds % 3600U) / 60U;
    uint32_t seconds = totalSeconds % 60U;

    snprintf(buffer, len, "%02lu:%02lu:%02lu",
             (unsigned long)hours,
             (unsigned long)minutes,
             (unsigned long)seconds);
}

//Interrupt Handlers / Callbacks


/* This would be called by the timer ISR every 1 second */
void Timer_OneSecondCallback(void)
{
    oneSecondTick = true;
}

/* This would be called from GPIO EXTI callback */
void GPIO_InputCallback(uint16_t pin, bool pinState)
{
    if (pin == PHONE_SENSOR_PIN)
    {
        phonePresent = pinState;
        displayUpdateRequired = true;
    }
    else if (pin == BTN_ADD_HOUR_PIN)
    {
        if (currentState == STATE_IDLE || currentState == STATE_TIMER_SETUP)
        {
            if (selectedTimeSeconds + SECONDS_PER_HOUR <= MAX_SESSION_TIME)
            {
                selectedTimeSeconds += SECONDS_PER_HOUR;
                displayUpdateRequired = true;
            }
        }
    }
    else if (pin == BTN_ADD_30MIN_PIN)
    {
        if (currentState == STATE_IDLE || currentState == STATE_TIMER_SETUP)
        {
            if (selectedTimeSeconds + SECONDS_PER_30MIN <= MAX_SESSION_TIME)
            {
                selectedTimeSeconds += SECONDS_PER_30MIN;
                displayUpdateRequired = true;
            }
        }
    }
}
